{
  "imports": {
    "@std/fmt": "jsr:@std/fmt@^1.0.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.10",
    "fs": "node:fs",
    "os": "node:os",
    "axios": "npm:axios@^1.10.0",
    "better-sqlite3": "npm:better-sqlite3@^11.10.0",
    "chalk": "npm:chalk@^5.4.1",
    "commander": "npm:commander@^12.1.0",
    "debug": "npm:debug@^4.4.1",
    "detect-indent": "npm:detect-indent@^7.0.1",
    "dot-json": "npm:dot-json@^1.3.0",
    "file-type": "npm:file-type@^19.6.0",
    "filehound": "npm:filehound@^1.17.6",
    "filesniffer": "npm:filesniffer@^1.0.3",
    "flat": "npm:flat@^6.0.1",
    "fs-extra": "npm:fs-extra@^11.3.0",
    "gitconfiglocal": "npm:gitconfiglocal@^2.1.0",
    "js-yaml": "npm:js-yaml@^4.1.0",
    "lockfile": "npm:lockfile@^1.0.4",
    "moment": "npm:moment@^2.30.1",
    "nanoid": "npm:nanoid@^5.1.5",
    "nordchalk": "npm:nordchalk@^0.1.4",
    "p-exiftool": "npm:p-exiftool@^1.0.1",
    "path": "npm:path@^0.12.7",
    "pdfkit": "npm:pdfkit",
    "shelljs.exec": "npm:shelljs.exec@^1.1.8",
    "shelljs": "npm:shelljs@^0.8.5",
    "sprintf-js": "npm:sprintf-js@^1.1.3",
    "string-similarity": "npm:string-similarity@^4.0.4",
    "sugar-date": "npm:sugar-date@^2.0.6",
    "underscore-keypath": "npm:underscore-keypath@^0.9.3",
    "xlsx": "npm:xlsx@^0.18.5",
    "zlib": "npm:zlib@^1.0.5",

    "castv2-client": "npm:castv2-client@^1.2.0",
    "multicast-dns": "npm:multicast-dns@^7.2.5",
    "google-auth-library": "npm:google-auth-library@^9.0.0",
    "oak": "https://deno.land/x/oak@v12.6.1/mod.ts"
  },

  "compilerOptions": {
    "lib": ["deno.window",  "deno.ns",  "deno.unstable"],
    "strict": true
  },

  "include": ["./", "./bin", "./lib"],
  "exclude": [ "./dist", "./off"],

  "nodeModulesDir": "auto",

  "unstable": ["cron", "kv", "webgpu"],

  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["ban-untagged-todo"],
      "exclude": ["no-unused-vars"]
    }
  },

  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },

  "tasks": {
    "test": {
      "command": "echo 'run tests'"
    },
    "clean": {
      "command": "echo cleaning && rm -rf dist"
    },
    "compile:photocast": "deno_compile --flags='-A' photocast.ts",

    "install": {
      "description": "install built scripts to users bin dir",
      "command": "/bin/cp -av dist/* $HOME/bin",
      "dependencies": ["test", "compile:all"]
    },
    "install:clean": {
      "description": "install cleanly built scripts to users bin dir",
      "command": "/bin/cp -av dist/* $HOME/bin",
      "dependencies": ["clean", "install"]
    }

  },
  "allowScripts": {
    "allow": [],
    "deny": ["npm:better-sqlite3@11.10.0", "npm:canvas@3.2.0", "npm:zlib@1.0.5"]
  }
}

