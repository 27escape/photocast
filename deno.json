{
  "version": "1.0.0",

  "imports": {
    "@std/fmt": "jsr:@std/fmt@^1.0.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.10",
    "fs": "node:fs",
    "os": "node:os",
    "commander": "npm:commander@^12.1.0",
    "castv2-client": "npm:castv2-client@^1.2.0",
  },

  "compilerOptions": {
    "lib": ["deno.window",  "deno.ns",  "deno.unstable"],
    "strict": true
  },

  "include": ["./", "./bin", "./lib"],
  "exclude": [ "./dist", "./off"],

  "nodeModulesDir": "auto",

  "unstable": ["cron", "kv", "webgpu"],

  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["ban-untagged-todo"],
      "exclude": ["no-unused-vars"]
    }
  },

  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },

  "tasks": {
    "test": {
      "command": "echo 'run tests'"
    },
    "clean": {
      "command": "echo cleaning && rm -rf dist"
    },
    "compile:photocast": "deno_compile --flags='-A' photocast.ts",

    "install": {
      "description": "install built scripts to users bin dir",
      "command": "/bin/cp -av dist/* $HOME/bin",
      "dependencies": ["test", "compile:photocast"]
    },
    "install:clean": {
      "description": "install cleanly built scripts to users bin dir",
      "command": "/bin/cp -av dist/* $HOME/bin",
      "dependencies": ["clean", "install"]
    }

  },
  "allowScripts": {
    "allow": ["npm:protobufjs@6.11.6"],
    "deny": ["npm:better-sqlite3@11.10.0", "npm:canvas@3.2.0", "npm:zlib@1.0.5"]
  }
}

